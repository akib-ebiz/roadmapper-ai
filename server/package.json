{
  "name": "roadmapper-ai-server",
  "version": "1.0.0",
  "description": "Roadmapper AI Backend - Express + MongoDB",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "test": "jest --runInBand",
    "test:watch": "jest --watchAll",
    "lint": "eslint src/**/*.js",
    "lint:fix": "eslint src/**/*.js --fix",
    "format": "prettier --write src/**/*.js"
  },
  "dependencies": {
    "@google/generative-ai": "^0.21.0",
    "bcrypt": "5.1.1",
    "cors": "2.8.5",
    "dotenv": "16.4.5",
    "express": "4.19.2",
    "express-rate-limit": "7.3.1",
    "groq-sdk": "^0.8.0",
    "helmet": "7.1.0",
    "jsonwebtoken": "9.0.2",
    "mongoose": "8.4.1",
    "morgan": "1.10.0",
    "winston": "3.13.0",
    "zod": "3.23.8"
  },
  "devDependencies": {
    "eslint": "8.57.0",
    "jest": "29.7.0",
    "nodemon": "3.1.3",
    "prettier": "3.3.2",
    "supertest": "7.0.0"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": [
      "**/tests/**/*.test.js"
    ],
    "collectCoverageFrom": [
      "src/**/*.js"
    ],
    "testEnvironmentOptions": {},
    "setupFiles": [
      "<rootDir>/tests/setup.js"
    ]
  }
}
